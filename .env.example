# LLM API Configuration (supports any OpenAI-compatible API)
# Examples: OpenAI (https://platform.openai.com/), Mistral (https://mistral.ai/),
#           or a local LM Studio instance (http://127.0.0.1:1234/v1)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
# Set to 'false' for local models (e.g. LM Studio) that don't support JSON mode
LLM_JSON_MODE=true

# ===== Graphiti Memory Graph Configuration =====
# Requires: running Neo4j instance + LM Studio serving an embedding model

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# LM Studio embedding model (OpenAI-compatible)
GRAPHITI_EMBED_BASE_URL=http://localhost:1234/v1
GRAPHITI_EMBED_MODEL=mlx-community/Qwen3-Embedding-4B-mxfp8
GRAPHITI_EMBED_API_KEY=lm-studio

# Memory backend selection
# Set to 'zep' to use Zep Cloud instead of Graphiti (default: graphiti)
MEMORY_BACKEND=graphiti

# Zep Cloud API key (required when MEMORY_BACKEND=zep)
# ZEP_API_KEY=your_zep_api_key

# ===== Accelerated LLM Configuration (Optional) =====
# A second, faster model endpoint for less complex tasks
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== API Authentication =====
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
API_KEY=your_api_key_here
# Must match API_KEY above
VITE_API_KEY=your_api_key_here
# Flask session secret — generate the same way as API_KEY
SECRET_KEY=your_secret_key_here
